exec-approvals.json

# ── Backups ───────────────────────────────────────────────────────────────────
*.bak
*.bak.*

# ── Logs ─────────────────────────────────────────────────────────────────────
logs/

# ── Node / OS junk ───────────────────────────────────────────────────────────
node_modules/
.DS_Store
*.log
