# ── Sensitive auth & credentials ─────────────────────────────────────────────
auth-profiles.json
token-cache.json
*.key
*.pem
*.cert
*.p12
credentials.json

# ── Session JSONL files (backed up to Google Drive separately) ────────────────
sessions/*.jsonl
*/sessions/*.jsonl

